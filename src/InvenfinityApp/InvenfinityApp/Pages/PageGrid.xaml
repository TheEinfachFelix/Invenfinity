<Page x:Class="InvenfinityApp.Views.ViewGrid"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InvenfinityApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      xmlns:dto="clr-namespace:Backend.Application.DTOs;assembly=Backend"
      xmlns:uc="clr-namespace:InvenfinityApp.Elements"
      Title="Grid">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- LEFT TREE -->
        <uc:LocationTree Grid.Column="0"/>
        <Button Content="Edit Locations"
                Grid.Column="0"
                VerticalAlignment="Bottom"
                Margin="10"
                Click="EditLocations_Click"/>
        <!-- RIGHT GRID AREA -->
        <uc:GridBoard Grid.Column="1"/>

    </Grid>
</Page>
