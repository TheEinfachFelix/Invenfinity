<Page x:Class="InvenfinityApp.Views.ViewGrid"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InvenfinityApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      xmlns:dto="clr-namespace:Backend.Application.DTOs;assembly=Backend"
      xmlns:uc="clr-namespace:InvenfinityApp.Elements"
      Title="Grid">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- LEFT TREE -->
        <uc:LocationTree Grid.Column="0" Root="{Binding RootItems}"/>
        <!-- RIGHT GRID AREA -->
        <ScrollViewer Grid.Column="1">
            <Grid>

                <!-- Hintergrund Grid -->
                <ItemsControl ItemsSource="{Binding Grid.Bins}">

                    <!-- Panel = echtes WPF Grid -->
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Grid x:Name="DrawGrid"
                                  Background="#222"
                                  ShowGridLines="True"
                                  AllowDrop="True"
                                  Drop="Grid_Drop"
                                  DragOver="Grid_DragOver"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <!-- Positionierung der Bins -->
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Grid.Column" Value="{Binding X}" />
                            <Setter Property="Grid.Row" Value="{Binding Y}" />
                            <Setter Property="Grid.ColumnSpan" Value="{Binding WidthCells}" />
                            <Setter Property="Grid.RowSpan" Value="{Binding HeightCells}" />
                            <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <!-- BIN TEMPLATE -->
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type dto:DTOBin}">
                            <Border BorderBrush="White"
                                    BorderThickness="2"
                                    Background="DarkSlateGray"
                                    CornerRadius="4"
                                    Padding="4"
                                    AllowDrop="True"
                                    PreviewMouseLeftButtonDown="Bin_MouseDown"
                                    PreviewMouseMove="Bin_MouseMove"
                                    Drop="Bin_Drop">

                                <StackPanel>
                                    <TextBlock Text="Bin"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,5"/>

                                    <!-- PARTS -->
                                    <ItemsControl ItemsSource="{Binding Parts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="Orange"
                                                        Margin="2"
                                                        Padding="2"
                                                        CornerRadius="2">
                                                    <TextBlock Text="{Binding PartName}"
                                                               FontSize="12"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </Grid>
        </ScrollViewer>

    </Grid>
</Page>
