<Page x:Class="InvenfinityApp.Pages.PageBinEdit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InvenfinityApp.Pages"
      xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="White"
      xmlns:uc="clr-namespace:InvenfinityApp.Elements"
      Title="PageGridEdit">

    <StackPanel>
        <TextBlock Text="Bin Bearbeiten"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

        <Grid Margin="10" Height="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <Button 
                    Content="Bin Erstellen" 
                    HorizontalAlignment="Left"
                    Width="100"
                    Grid.Column="0"
                    Height="20"
                    Margin="0,0,10,0"
                    Click="Create_Bin_Click"/>

            <TextBlock 
                    Text="Gridless Bins" 
                    Grid.Column="1" 
                    Margin="0,0,10,0"/>
            
            <uc:Dropdown
                    Grid.Column="2"
                    Margin="0,0,10,0"
                    ItemsSource="{Binding GridlessBins}"
                    SelectedId="{Binding SelectedGridlessBinId}"/>

            <Button Content="Gridless Bin Laden" HorizontalAlignment="Right"
                    Grid.Column="3"
                    Click="Load_Gridless_Bin_Click"/>
        </Grid>

        <DockPanel>
            <StackPanel MinWidth="200" Margin="10">



            <TextBlock Text="Selected Bin ID"/>
            <TextBox Text="{Binding SelectedBinId}"
                     IsEnabled="False" />

            <TextBlock Text="Type:" Margin="0,15,0,0"/>
            <TextBox Text="{Binding BinTypeName}"
                     IsEnabled="False" />


            <TextBlock Text="Grid ID" Margin="0,15,0,0"/>
            <uc:Dropdown
                    ItemsSource="{Binding Grids}"
                    SelectedId="{Binding SelectedGridID}"
                    AllowEmpty="True" />


            <Button Content="Speichern" HorizontalAlignment="Left"
                    Width="100"
                    Margin="0,15,10,0"
                    IsEnabled="{Binding UpdatePossible}"
                    Click="Save_Bin_Click"/>

            <Button Content="Löschen" HorizontalAlignment="Left"
                    Width="100"
                    Margin="0,15,10,0"
                    IsEnabled="{Binding DelPossible}"
                    Click="Del_Bin_Click"/>

        </StackPanel>
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,10,10">
                <StackPanel>
                    <TextBlock Text="Slots"/>

                    <ListBox ItemsSource="{Binding Parts}" 
                         SelectedIndex="{Binding SelectedSlotIndex}" 
                         Height="Auto">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Padding="5" Margin="0,0,5,0">
                                        <TextBlock Text="{Binding Name}" />
                                    </Border>

                                    <Button Grid.Column="1"
                                        Content="↑"
                                        Tag="{Binding}"
                                        Click="MovePartUp_Click"/>

                                    <Button Grid.Column="2"
                                        Content="↓"
                                        Tag="{Binding}"
                                        Click="MovePartDown_Click"/>
                                    <Button Grid.Column="3"
                                        Content="Entfernen"
                                        Tag="{Binding}"
                                        Click="RemovePart_Click"/>

                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="Part hinzufügen" Margin="0,15,0,0"/>

                    <TextBox Text="{Binding PartSearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <ListBox ItemsSource="{Binding SearchResults}" 
                         Height="150"
                         MouseDoubleClick="AddPart_DoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Padding="5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
        
    </StackPanel>
</Page>
