<Page x:Class="InvenfinityApp.Pages.PageLocationTreeEdit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InvenfinityApp.Pages"
      xmlns:uc="clr-namespace:InvenfinityApp.Elements"

      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageLocationTreeEdit">



    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- LEFT TREE -->
        <uc:LocationTree Grid.Column="0" x:Name="LocationTree"/>

        <TextBlock Text="{Binding ElementName=LocationTree, Path=SelectedTreeItem, Converter={StaticResource TreePathConverter}}"
                   
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Grid.Column="1"/>
    </Grid>


</Page>
