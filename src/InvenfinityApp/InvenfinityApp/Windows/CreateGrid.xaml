<Window x:Class="InvenfinityApp.Windows.CreateGrid"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvenfinityApp.Windows"
        xmlns:uc="clr-namespace:InvenfinityApp.Elements"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"

        mc:Ignorable="d"
        Title="CreateGrid" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- LEFT TREE -->
        <uc:LocationTree Grid.Column="0" x:Name="locTree"/>

        <StackPanel Grid.Column="1">

            <TextBlock Text="Location Erstellen"
               FontSize="20"
               FontWeight="Bold"
               Margin="0,0,0,20"/>

            <!-- Name -->
            <TextBlock Text="Name"/>
            <TextBox x:Name="NameVal"/>

            <!-- Parent -->
            <TextBlock Text="ParentId" Margin="0,15,0,0"/>
            <TextBox x:Name="ParentVal"
             IsEnabled="False" />

            <!-- Grid Size -->
            <TextBlock Text="X Size" Margin="0,15,0,0"/>
            <xctk:IntegerUpDown
                    x:Name="XsizeVal"
                    Minimum="1"
                    Maximum="20"
                    Value="2"
                    Width="100"
                    HorizontalAlignment="Left"/>

            <TextBlock Text="Y Size" Margin="0,5,0,0"/>
            <xctk:IntegerUpDown
                    x:Name="YsizeVal"
                    Minimum="1"
                    Maximum="20"
                    Value="2"
                    Width="100"
                    HorizontalAlignment="Left"/>

                <Button Content="Erstellen" x:Name="CreateBtn" HorizontalAlignment="Left"
                Width="100"
                Margin="0,0,10,0"
                Click="Create_Click"/>

        </StackPanel>

    </Grid>
</Window>
