<Window x:Class="InvenfinityApp.Windows.CreatePart"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvenfinityApp.Windows"
        mc:Ignorable="d"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="CreatePart" Height="450" Width="800">
    <StackPanel>
        <TextBlock Text="Part Erstellen"
               FontSize="20"
               FontWeight="Bold"
               Margin="0,0,0,20"/>

        <!-- Parent -->
        <TextBlock Text="InventreeID" Margin="0,15,0,0"/>

        <xctk:IntegerUpDown
                    x:Name="InventreeIdVal"
                    Width="100"
                    HorizontalAlignment="Left"/>

        <Button Content="Erstellen" x:Name="CreateBtn" HorizontalAlignment="Left"
                Width="100"
                Margin="0,15,10,0"
                Click="Create_Click"/>

    </StackPanel>
</Window>
