<Window x:Class="InvenfinityApp.Windows.CreateBin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvenfinityApp.Windows"
        xmlns:uc="clr-namespace:InvenfinityApp.Elements"
        mc:Ignorable="d"
                xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"

        Title="CreateBin" Height="450" Width="800">
    <StackPanel Margin="15">
        <TextBlock Text="Bin Erstellen"
           FontSize="20"
           FontWeight="Bold"
           Margin="0,0,0,20"/>

        <TextBlock Text="Grid" Margin="0,15,0,0"/>
        <uc:Dropdown
                    ItemsSource="{Binding Grids}"
                    SelectedId="{Binding SelectedGridId}"
                    AllowEmpty="True" />
        
        <DockPanel>
            <TextBlock Text="ID: "/>
            <TextBlock Text="{Binding SelectedGridId}"/>
        </DockPanel>
        
        <TextBlock Text="Bin Type" Margin="0,15,0,0"/>
        <uc:Dropdown
                    ItemsSource="{Binding BinTypes}"
                    SelectedId="{Binding SelectedBinTypeId}" />
        <DockPanel Width="200" HorizontalAlignment="Left">
            <TextBlock Text="ID: "/>
            <TextBlock Text="{Binding SelectedBinTypeId}"/>
            <Button Content="BinType Erstellen" HorizontalAlignment="Right"
            Width="100"
            Click="Create_BinType_Click"/>
        </DockPanel>

        <Button Content="Bin Erstellen" x:Name="CreateBtn" HorizontalAlignment="Left"
            Width="100"
            Margin="0,15,0,0"
            Click="Create_Click"
                IsEnabled="{Binding canCreate}"/>

    </StackPanel>
</Window>
