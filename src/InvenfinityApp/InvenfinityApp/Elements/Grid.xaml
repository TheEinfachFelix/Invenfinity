<UserControl x:Class="InvenfinityApp.Elements.Grid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvenfinityApp.Elements"
             xmlns:dto="clr-namespace:Backend.Application.DTOs;assembly=Backend"
             xmlns:uc="clr-namespace:InvenfinityApp.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer Grid.Column="1">
        <Grid>

            <!-- Hintergrund Grid -->
            <ItemsControl ItemsSource="{Binding Grid.Bins}">

                <!-- Panel = echtes WPF Grid -->
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid x:Name="DrawGrid"
                          Background="#222"
                          ShowGridLines="True"
                          AllowDrop="True"
                          Drop="Grid_Drop"
                          DragOver="Grid_DragOver"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- Positionierung der Bins -->
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Grid.Column" Value="{Binding X}" />
                        <Setter Property="Grid.Row" Value="{Binding Y}" />
                        <Setter Property="Grid.ColumnSpan" Value="{Binding WidthCells}" />
                        <Setter Property="Grid.RowSpan" Value="{Binding HeightCells}" />
                        <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <!-- BIN TEMPLATE -->
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type dto:DTOBin}">
                        <uc:GridBin/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
