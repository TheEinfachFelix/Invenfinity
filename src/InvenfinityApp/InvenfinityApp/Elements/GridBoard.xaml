<UserControl x:Class="InvenfinityApp.Elements.GridBoard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvenfinityApp.Elements"
             xmlns:dto="clr-namespace:Backend.Application.DTOs;assembly=Backend"
             xmlns:uc="clr-namespace:InvenfinityApp.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <ScrollViewer>
        <Grid x:Name="DrawGrid"
      Background="#222"
      ShowGridLines="True"
      AllowDrop="True"
      Drop="Grid_Drop"
      DragOver="Grid_DragOver">

            
        </Grid>
    </ScrollViewer>
</UserControl>
